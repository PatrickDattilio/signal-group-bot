<configuration>
    <!--
      Levels from environment (e.g. Railway): defaults INFO.
      - SIGNALBOT_LOG_LEVEL: root logger
      - SIGNALBOT_SIGNAL_LOG_LEVEL: JSON-RPC + signal-cli client (set DEBUG to see full JSON-RPC response lines
        from com.signalbot.signal.SignalCliClient, or set SIGNALBOT_LOG_RPC_RAW=1 in the app instead)
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%-5level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.signalbot.signal" level="${SIGNALBOT_SIGNAL_LOG_LEVEL:-INFO}"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="io.ktor" level="INFO"/>
    <logger name="Exposed" level="WARN"/>

    <root level="${SIGNALBOT_LOG_LEVEL:-INFO}">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
